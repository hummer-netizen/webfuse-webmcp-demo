{
  "manifest_version": 3,
  "version": "2.0",
  "name": "WebMCP Bridge Demo",
  "description": "AI agent that sees and controls any website via Webfuse — WebMCP-grade access today.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
