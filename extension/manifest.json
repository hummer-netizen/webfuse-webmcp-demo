{
  "manifest_version": 3,
  "version": "3.0",
  "name": "WebMCP Bridge Demo",
  "description": "AI agent with community-contributed WebMCP Hub tools + Webfuse proxy fallback. Real browser, real session.",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "js": ["content.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "host_permissions": [
    "https://proxy.webfuse.it/*",
    "https://www.webmcp-hub.com/*",
    "https://webmcp-hub.com/*"
  ]
}
